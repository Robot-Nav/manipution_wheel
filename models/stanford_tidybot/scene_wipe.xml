<mujoco model="tidybot wipe scene">
  <include file="tidybot.xml"/>

  <statistic center="0.4 0 0.6" extent="1.2" meansize="0.05"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.1 0.1 0.1" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5"/>
    <texture name="table_tex" type="2d" builtin="checker" rgb1="0.6 0.4 0.2" rgb2="0.5 0.35 0.18" width="300" height="300"/>
    <material name="table_material" texture="table_tex" texuniform="true" texrepeat="2 2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- Table -->
    <body name="table" pos="0.55 0 0">
      <geom name="table_top" type="box" size="0.35 0.35 0.02" pos="0 0 0.38" rgba="0.6 0.4 0.2 1" material="table_material" mass="5"/>
      <geom name="leg1" type="cylinder" size="0.02 0.19" pos="0.28 0.28 0.19" rgba="0.4 0.25 0.1 1"/>
      <geom name="leg2" type="cylinder" size="0.02 0.19" pos="-0.28 0.28 0.19" rgba="0.4 0.25 0.1 1"/>
      <geom name="leg3" type="cylinder" size="0.02 0.19" pos="0.28 -0.28 0.19" rgba="0.4 0.25 0.1 1"/>
      <geom name="leg4" type="cylinder" size="0.02 0.19" pos="-0.28 -0.28 0.19" rgba="0.4 0.25 0.1 1"/>
    </body>

    <!-- Sponge on the table (pick up before wiping) -->
    <body name="sponge" pos="0.55 0.15 0.417">
      <freejoint/>
      <inertial mass="0.05" pos="0 0 0" diaginertia="0.001 0.001 0.001"/>
      <geom name="sponge_geom" type="box" size="0.03 0.03 0.015" rgba="0.9 0.7 0.2 1"
        friction="1.5 0.8 0.8" contype="1" conaffinity="1" group="0"
        solimp="0.95 0.99 0.001" solref="0.004 1"/>
    </body>
  </worldbody>
</mujoco>
